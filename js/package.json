{
  "name": "@fugle/marketdata",
  "version": "0.2.0-rc.3",
  "description": "Fugle marketdata SDK for Node.js - REST and WebSocket client",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "marketdata-js",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "typed-emitter": "^2.1.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build -p marketdata-js --platform --release && node scripts/postbuild.js",
    "build:debug": "napi build -p marketdata-js --platform && node scripts/postbuild.js",
    "postbuild": "node scripts/postbuild.js",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "validate-types": "node validate_types.js",
    "test": "jest",
    "test:ci": "jest --ci --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fugle/fugle-marketdata-sdk",
    "directory": "js"
  },
  "keywords": [
    "fubon",
    "marketdata",
    "stock",
    "futures",
    "options",
    "trading",
    "napi-rs",
    "rust"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "types.d.ts",
    "*.node"
  ]
}
