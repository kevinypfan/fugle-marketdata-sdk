{
  "name": "@fugle/marketdata",
  "version": "0.2.0",
  "description": "Fugle marketdata SDK for Node.js - REST and WebSocket client",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "marketdata-js",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1"
  },
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build -p marketdata-js --platform --release",
    "build:debug": "napi build -p marketdata-js --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fugle/fugle-marketdata-sdk",
    "directory": "js"
  },
  "keywords": [
    "fubon",
    "marketdata",
    "stock",
    "futures",
    "options",
    "trading",
    "napi-rs",
    "rust"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
